# Slack app credentials (Socket Mode). Get these from your Slack app config.
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-app-token
# Channel where approval cards are posted (e.g. #general)
AEGIS_DEFAULT_CHANNEL=C0XXXXXXXXX

# Optional
# AEGIS_TTL_SECONDS=900
# AEGIS_DEMO_MODEL=us.anthropic.claude-sonnet-4-6
# AEGIS_DEMO_REGION=us-east-1

# AWS credentials for Amazon Bedrock are read from the default AWS credential
# chain (e.g. `aws login`, ~/.aws/credentials, or environment variables).
